pipeline {
    agent any

    stages {
        stage('Create Namespaces') {
            steps {
                sh '''
                    kubectl create namespace helm-lab   --dry-run=client -o yaml | kubectl apply -f -
                    kubectl create namespace monitoring --dry-run=client -o yaml | kubectl apply -f -
                '''
            }
        }

        stage('Create PVC') {
            steps {
                sh '''
                    cat <<EOFPVC | kubectl apply -f -
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: flask-pvc-helm2
  namespace: helm-lab
spec:
  accessModes: [ReadWriteOnce]
  resources:
    requests:
      storage: 100Mi
EOFPVC
                '''
            }
        }

        stage('Deploy MariaDB') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'db-creds', usernameVariable: 'DB_USER', passwordVariable: 'DB_PASS')]) {
                    sh '''
                        helm repo add bitnami https://charts.bitnami.com/bitnami || true
                        helm repo update
                        helm upgrade --install mariadb-lab bitnami/mariadb \
                          -n helm-lab \
                          --set auth.rootPassword=$DB_PASS \
                          --set auth.database=appdb \
                          --set auth.username=$DB_USER \
                          --set auth.password=$DB_PASS \
                          --set primary.resources.requests.cpu=100m \
                          --set primary.resources.requests.memory=256Mi \
                          --set primary.resources.limits.cpu=250m \
                          --set primary.resources.limits.memory=512Mi \
                          --wait --timeout 300s
                    '''
                }
            }
        }

        stage('Create DB Secret for App') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'db-creds', usernameVariable: 'DB_USER', passwordVariable: 'DB_PASS')]) {
                    sh '''
                        kubectl create secret generic db-file-secret \
                          --from-literal=DB_PASSWORD=$DB_PASS \
                          -n helm-lab --dry-run=client -o yaml | kubectl apply -f -
                    '''
                }
            }
        }

        stage('Deploy Monitoring Stack') {
            steps {
                sh '''
                    helm repo add prometheus-community https://prometheus-community.github.io/helm-charts || true
                    helm repo update
                    helm upgrade --install kube-prom prometheus-community/kube-prometheus-stack \
                      -n monitoring \
                      --set alertmanager.enabled=false \
                      --set nodeExporter.enabled=false \
                      --set kubeStateMetrics.enabled=false \
                      --set prometheusOperator.resources.requests.cpu=50m \
                      --set prometheusOperator.resources.requests.memory=128Mi \
                      --set prometheus.prometheusSpec.resources.requests.cpu=100m \
                      --set prometheus.prometheusSpec.resources.requests.memory=256Mi \
                      --set grafana.resources.requests.cpu=50m \
                      --set grafana.resources.requests.memory=128Mi \
                      --set prometheus.prometheusSpec.serviceMonitorSelectorNilUsesHelmValues=false \
                      --wait --timeout 600s
                '''
            }
        }
    }

    post {
        success {
            echo 'Infrastructure deployed successfully!'
            sh 'kubectl get pods -n helm-lab'
            sh 'kubectl get pods -n monitoring'
        }
        failure {
            echo 'Infrastructure deployment failed. Check logs.'
        }
    }
}
