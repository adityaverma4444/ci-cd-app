// Full CI/CD Pipeline: Checkout → Test → Build → Load Image → Deploy
pipeline {

    agent none

    environment {
        IMAGE_NAME = 'flask-cicd-app'
        IMAGE_TAG  = "build-${BUILD_NUMBER}"
        K8S_NAMESPACE = 'dev-lab'
    }

    stages {

        stage('Checkout') {
            agent any
            steps {
                checkout scm
            }
        }

        stage('Install & Test') {
            agent {
                docker {
                    image 'python:3.12-slim'
                    args '-v pip-cache:/root/.cache/pip --user root'
                }
            }
            steps {
                dir('flask-cicd-app') {
                    sh 'pip install -r requirements.txt'
                    sh 'pytest test_app.py -v'
                }
            }
        }

        stage('Docker Build') {
            agent any
            steps {
                dir('flask-cicd-app') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                    sh "docker build -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        // Transfer image from Jenkins' Docker (DinD) into Minikube's Docker
        // then update the K8s deployment to use the new image
        stage('Deploy to K8s') {
            agent any
            steps {
                dir('flask-cicd-app') {
                    sh 'kubectl create namespace ${K8S_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -'
                    sh 'kubectl apply -f k8s/pv-pvc.yaml -n ${K8S_NAMESPACE}'
                    sh 'kubectl apply -f k8s/deployment.yaml -n ${K8S_NAMESPACE}'
                    sh 'kubectl apply -f k8s/service.yaml -n ${K8S_NAMESPACE}'
                    sh "docker save ${IMAGE_NAME}:${IMAGE_TAG} -o /tmp/flask-image.tar"
                    sh 'kubectl delete pod image-loader -n ${K8S_NAMESPACE} --ignore-not-found'
                    sh 'kubectl apply -f k8s/image-loader.yaml -n ${K8S_NAMESPACE}'
                    sh 'kubectl wait --for=condition=Ready pod/image-loader -n ${K8S_NAMESPACE} --timeout=120s'
                    sh 'kubectl cp /tmp/flask-image.tar ${K8S_NAMESPACE}/image-loader:/tmp/flask-image.tar'
                    sh 'kubectl exec -n ${K8S_NAMESPACE} image-loader -- docker load -i /tmp/flask-image.tar'
                    sh 'kubectl delete pod image-loader -n ${K8S_NAMESPACE} --ignore-not-found'
                    sh 'rm -f /tmp/flask-image.tar'
                    sh "kubectl set image deployment/flask-cicd-app flask-cicd=${IMAGE_NAME}:${IMAGE_TAG} -n ${K8S_NAMESPACE}"
                    sh 'kubectl rollout status deployment/flask-cicd-app -n ${K8S_NAMESPACE} --timeout=120s'
                    sh 'kubectl get pods -n ${K8S_NAMESPACE} -l app=flask-cicd'
                }
            }
        }
    }

    post {
        success {
            echo "CI/CD Pipeline succeeded! Deployed: ${IMAGE_NAME}:${IMAGE_TAG}"
        }
        failure {
            echo 'Pipeline failed. Check test, build, or deploy logs.'
        }
    }
}
