// Full CI/CD Pipeline: Checkout → Test → Build → Load Image → Deploy

pipeline {

    agent none

    environment {
        IMAGE_NAME = 'flask-cicd-app'
        IMAGE_TAG  = "build-${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            agent any
            steps {
                checkout scm
            }
        }

        stage('Install & Test') {
            agent {
                docker {
                    image 'python:3.12-slim'
                    args '-v pip-cache:/root/.cache/pip --user root'
                }
            }
            steps {
                dir('flask-cicd-app') {
                    sh 'pip install -r requirements.txt'
                    sh 'pytest test_app.py -v'
                }
            }
        }

        stage('Docker Build') {
            agent any
            steps {
                dir('flask-cicd-app') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                    sh "docker build -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Transfer Image to Minikube') {
            agent any
            steps {
                dir('flask-cicd-app') {
                    sh "docker save ${IMAGE_NAME}:${IMAGE_TAG} -o /tmp/flask-image.tar"
                    sh 'kubectl delete pod image-loader --ignore-not-found'
                    sh 'kubectl apply -f k8s/image-loader.yaml'
                    sh 'kubectl wait --for=condition=Ready pod/image-loader --timeout=120s'
                    sh 'kubectl cp /tmp/flask-image.tar image-loader:/tmp/flask-image.tar'
                    sh 'kubectl exec image-loader -- docker load -i /tmp/flask-image.tar'
                    sh 'kubectl delete pod image-loader --ignore-not-found'
                    sh 'rm -f /tmp/flask-image.tar'
                }
            }
        }

        stage('Deploy with Helm') {
            agent any
            steps {
                dir('flask-cicd-app') {
                    sh """
                        helm upgrade --install flask-cicd-helm2 helm/flask-cicd-app \
                            -n helm-lab \
                            --set image.tag=${IMAGE_TAG} \
                            --wait --timeout 120s
                    """
                    sh 'kubectl get pods -n helm-lab'
                }
            }
        }
    }

    post {
        success {
            echo "CI/CD Pipeline succeeded! Deployed via Helm: ${IMAGE_NAME}:${IMAGE_TAG}"
        }
        failure {
            echo 'Pipeline failed. Check test, build, or deploy logs.'
        }
    }
}