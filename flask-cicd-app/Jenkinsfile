pipeline {
    agent none

    environment {
        REGISTRY_REPO = 'adityaverma268/flask-cicd-app'
        IMAGE_TAG     = "build-${BUILD_NUMBER}"
        TF_DIR        = 'flask-cicd-app/terraform/flask-app'
        TF_IN_AUTOMATION = 'true'
    }

    stages {
        stage('Checkout') {
            agent any
            steps {
                checkout scm
            }
        }

        stage('Install & Test') {
            agent {
                docker {
                    image 'python:3.12-slim'
                    args '-v pip-cache:/root/.cache/pip --user root'
                }
            }
            steps {
                dir('flask-cicd-app') {
                    sh 'pip install -r requirements.txt'
                    sh 'pytest test_app.py -v'
                }
            }
        }

        stage('Docker Build') {
            agent any
            steps {
                dir('flask-cicd-app') {
                    sh "docker build -t ${REGISTRY_REPO}:${IMAGE_TAG} ."
                    sh "docker build -t ${REGISTRY_REPO}:latest ."
                }
            }
        }

        stage('Docker Push') {
            agent any
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
                    sh "docker push ${REGISTRY_REPO}:${IMAGE_TAG}"
                    sh "docker push ${REGISTRY_REPO}:latest"
                    sh 'docker logout'
                }
            }
        }

        stage('Terraform Init') {
            agent any
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform version'
                    sh 'terraform init -input=false -no-color'
                }
            }
        }

        stage('Terraform Plan') {
            agent any
            steps {
                dir("${TF_DIR}") {
                    withCredentials([usernamePassword(credentialsId: 'db-creds', usernameVariable: 'DB_USER', passwordVariable: 'DB_PASS')]) {
                        // TF_VAR_xxx env vars feed Terraform input variables
                        // (matches variables in variables.tf)
                        withEnv([
                            "TF_VAR_image_tag=${IMAGE_TAG}",
                            "TF_VAR_image_repo=${REGISTRY_REPO}",
                            "TF_VAR_mariadb_password=${DB_PASS}"
                        ]) {
                            sh 'terraform plan -input=false -no-color -out=tfplan'
                        }
                    }
                }
            }
        }

        stage('Terraform Apply') {
            agent any
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform apply -input=false -no-color -auto-approve tfplan'
                    sh 'terraform output'
                }
            }
        }

        stage('Verify Deployment') {
            agent any
            steps {
                sh 'kubectl get pods -n helm-lab'
                sh 'helm list -n helm-lab'
            }
        }
    }

    post {
        success {
            echo "tf-branch pipeline succeeded! Image ${REGISTRY_REPO}:${IMAGE_TAG} deployed via Terraform-managed Helm release."
        }
        failure {
            echo "Pipeline failed. If Terraform Apply failed, run 'terraform plan' locally in ${TF_DIR} to debug."
        }
    }
}
