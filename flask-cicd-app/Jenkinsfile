// Full CI/CD Pipeline: Checkout → Test → Build → Deploy
pipeline {

    agent none

    environment {
        IMAGE_NAME = 'flask-cicd-app'
        IMAGE_TAG  = "build-${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            agent any
            steps {
                checkout scm
            }
        }

        stage('Install & Test') {
            agent {
                docker {
                    image 'python:3.12-slim'
                    args '-v pip-cache:/root/.cache/pip --user root'
                }
            }
            steps {
                dir('flask-cicd-app') {
                    sh 'pip install -r requirements.txt'
                    sh 'pytest test_app.py -v'
                }
            }
        }

        stage('Docker Build') {
            agent any
            steps {
                dir('flask-cicd-app') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                    sh "docker build -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        // Deploy runs on Jenkins master where kubectl + kubeconfig are installed
        stage('Deploy to K8s') {
            agent any
            steps {
                dir('flask-cicd-app') {
                    sh "kubectl set image deployment/flask-cicd-app flask-cicd=${IMAGE_NAME}:${IMAGE_TAG}"
                    sh 'kubectl rollout status deployment/flask-cicd-app --timeout=60s'
                    sh 'kubectl get pods -l app=flask-cicd'
                }
            }
        }
    }

    post {
        success {
            echo "CI/CD Pipeline succeeded! Deployed: ${IMAGE_NAME}:${IMAGE_TAG}"
        }
        failure {
            echo 'Pipeline failed. Check test, build, or deploy logs.'
        }
    }
}
